# ~/.bashrc for agent container

# Suppress sudo hint
export SUDO_HINT_SHOWN=1

# Agent shortcuts
alias claude-yolo='claude --dangerously-skip-permissions'
alias codex-yolo='codex --dangerously-bypass-approvals-and-sandbox'

# Python venv helpers
# .venv (if present) is built for macOS — never use it inside this container
# Always use .linux_venv (set via UV_PROJECT_ENVIRONMENT=.linux_venv)
alias venv-check='
  [ -d .venv ] && echo "WARNING: .venv exists (macOS build, do not use)" || echo "No .venv found"
  [ -d .linux_venv ] && echo ".linux_venv OK" || echo "No .linux_venv yet — run: uv sync"
'
