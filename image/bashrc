# ~/.bashrc for agent container

# Suppress sudo hint
export SUDO_HINT_SHOWN=1

# Agent shortcuts
alias ccy='claude --dangerously-skip-permissions'
alias cx-yolo='codex --dangerously-bypass-approvals-and-sandbox'

# Auto-install VS Code extensions on first connection
# `code` CLI is only available when VS Code Remote is connected
if command -v code &>/dev/null && [ ! -f ~/.vscode-extensions-installed ]; then
    echo "[container] Installing VS Code extensions..."
    while IFS= read -r ext || [ -n "$ext" ]; do
        [[ "$ext" =~ ^#|^$ ]] && continue
        code --install-extension "$ext" --force &>/dev/null && echo "  + $ext" || echo "  ! $ext (failed)"
    done < ~/.vscode-extensions.txt
    touch ~/.vscode-extensions-installed
fi

# Python venv helpers
# .venv (if present) is built for macOS — never use it inside this container
# Always use .linux_venv (set via UV_PROJECT_ENVIRONMENT=.linux_venv)
alias venv-check='
  [ -d .venv ] && echo "WARNING: .venv exists (macOS build, do not use)" || echo "No .venv found"
  [ -d .linux_venv ] && echo ".linux_venv OK" || echo "No .linux_venv yet — run: uv sync"
'
